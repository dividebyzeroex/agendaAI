{
  "version": 2,
  "rewrites": [
    { "source": "/api/checkout", "destination": "/api/billing?action=checkout" },
    { "source": "/api/verify-session", "destination": "/api/billing?action=verify" },
    { "source": "/api/get-invoices", "destination": "/api/billing?action=invoices" },
    { "source": "/api/cancel-subscription", "destination": "/api/billing?action=cancel" },
    { "source": "/(.*)", "destination": "/" }
  ],
  "crons": [
    {
      "path": "/api/cron/bot-recepcao",
      "schedule": "0 8 * * *"
    }
  ]
}
